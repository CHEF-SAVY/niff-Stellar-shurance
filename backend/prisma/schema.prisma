// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Claim {
  id                Int       @id @default(autoincrement())
  policyId          String
  creatorAddress    String
  amount            String
  description       String?
  evidenceHash      String?
  status            ClaimStatus @default(PENDING)
  isFinalized       Boolean   @default(false)
  createdAtLedger   Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  updatedAtLedger   Int       @default(0)

  // Relations
  policy            Policy    @relation(fields: [policyId], references: [id])
  votes             Vote[]

  @@index([status])
  @@index([createdAt])
  @@index([policyId])
  @@map("claims")
}

model Vote {
  id            Int       @id @default(autoincrement())
  claimId       Int
  voterAddress  String
  vote          VoteType
  votingPower   String    @default("1")
  txHash        String?
  votedAtLedger Int
  createdAt     DateTime  @default(now())

  // Relations
  claim         Claim     @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@unique([claimId, voterAddress])
  @@index([voterAddress])
  @@index([claimId])
  @@map("votes")
}

model Policy {
  id                    String   @id
  name                  String
  description           String?
  coverageAmount        String
  premium               String
  durationDays          Int
  requiredVotes         Int      @default(5)
  votingPeriodLedgers   Int      @default(720) // ~1 hour at 5 sec/ledger
  votingDeadlineLedger  Int
  votingDeadlineTime    DateTime
  /// SEP-41 asset contract ID bound to this policy for premium and payout.
  /// Null for legacy policies created before multi-asset support.
  assetContractId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  claims                Claim[]

  @@map("policies")
}

model IndexerState {
  id              Int      @id @default(autoincrement())
  lastLedger      Int
  lastCursor      String?
  updatedAt       DateTime @updatedAt

  @@map("indexer_state")
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VoteType {
  YES
  NO
}

/// Off-chain metadata for allowlisted SEP-41 asset contracts.
/// Populated by the indexer when it observes AssetAdded events.
/// Used by the frontend and API to display correct symbol/decimals.
model AllowedAsset {
  /// SEP-41 contract address (Stellar strkey format).
  contractId  String   @id
  /// Token symbol, e.g. "USDC", "XLM". Populated off-chain.
  symbol      String?
  /// Decimal places, e.g. 7 for XLM/USDC on Stellar.
  decimals    Int      @default(7)
  /// Whether this asset is currently on the allowlist.
  isAllowed   Boolean  @default(true)
  /// Ledger at which the asset was added to the allowlist.
  addedAtLedger Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("allowed_assets")
}


